        },
        {
          "local_id": 599,
          "local_quot_id": 0,
          "local_product_id": 0,
          "product_name": "List of deliverables",
          "qty": 1.0,
          "unit": "",
          "rate": 0.0,
          "tax_rate": 0.0,
          "price": 0.0,
          "org_id": 38147,
          "description": "The systems that will be covered in this project as discussed in the meeting:\nLighting System\n•\n Power System\n\nLow Current systems (upon the request of the client)\nEarthing System\nLightning Protection System\nPanel Boards and cables calculations\nControl System for Automated Irrigation\n•\nPower system for Equipment\nSolar System Design\n•\nDrainage system\nWater supply system\nRainwater system\n•\nHVAC",
          "discount_amount": 0.0,
          "sequence": 0,
          "custom_field": "[]",
          "tax_amount": 0.0,
          "discount_rate": 0.0,
          "unique_key_fk_quotation": "faf928921104a4121745835244183",
          "unique_key_fk_product": "faf928921104a4121746015735315",
          "unique_key_quotation_product": "faf928921104a4121746018322302",
          "estimate_product_code": "",
          "taxable_flag": 0,
          "tax_list": "[]"
        },
        {
          "local_id": 600,
          "local_quot_id": 0,
          "local_product_id": 0,
          "product_name": "Project Description",
          "qty": 1.0,
          "unit": "",
          "rate": 0.0,
          "tax_rate": 0.0,
          "price": 0.0,
          "org_id": 38147,
          "description": "\rProject Title \r\nTIKRIT \"CUTFLOWER\" AGRICULTURAL PROJECT\r\nTikrit, Iraq\r\r\nProject Description\r\nCUTFLOWER is an agricultural project located in Tikrit, Iraq, with a total built-up area of approximately \r\n83,500 m2, integrating parking and loading areas, greenhouses, post-harvest facilities, \r\nclimate-controlled cultivation zones, water management stations, water tanks, solar panels areas, \r\nequipment and storage areas, packaging and logistics areas, administrative offices, control room, \r\nstaff accommodations, and visitor access zones. \r\nThe project prioritizes water-efficient irrigation, sustainable pest control, and energy-smart technologies, \r\naiming to ensure long-term productivity and ecological balance.",
          "discount_amount": 0.0,
          "sequence": 0,
          "custom_field": "[]",
          "tax_amount": 0.0,
          "discount_rate": 0.0,
          "unique_key_fk_quotation": "faf928921104a4121746032850049",
          "unique_key_fk_product": "faf928921104a4121746019588467",
          "unique_key_quotation_product": "faf928921104a4121746032902451",
          "estimate_product_code": "",
          "taxable_flag": 0,
          "tax_list": "[]"
        },
        {
          "local_id": 601,
          "local_quot_id": 0,
          "local_product_id": 0,
          "product_name": "List of deliverables",
          "qty": 1.0,
          "unit": "",
          "rate": 0.0,
          "tax_rate": 0.0,
          "price": 0.0,
          "org_id": 38147,
          "description": "The MEP scope of work shall include Design Report, Calculations, Drawing Plan Layouts, Riser Diagrams,\nSchedule of Equipment, Details, Bill of Quantities, and Specifications.\nThe Electro-Mechanical design shall be divided into the 4 phases:\nPHASE:\n1- CONCEPT DESIGN:\n2-SCHEMATIC DESIGN:\n3- DESIGN DEVELOPMENT:\n4- TENDER DOCUMENTS:\nDELIVERABLES:\n- Basis of Design Report.\n-Defining all required shafts and technical rooms.\n- Preliminary MEP system calculations.\n- Layout of main equipment.\n- Layout of main MEP system routings.\nHVAC System:\n- HVAC double line ducting layout.\n- Heat loss calculation.\n- Equipment sizing & Schedule of equipment.\nWater Supply System:\n- Water Supply layout (pipe routing & sizing)\n- Schedule of equipment (RO, pumps, HWT, etc...)\nDrainage System:\n- Soil & Waste layout (pipe routing & sizing)\n- Rain Water layout (pipe routing & sizing)\nPower System:\n-Electrical Power layout.\n- Diagrams & Details (MDB, ATS, SDB, MCC, etc...)\nLighting System:\n- Electrical Lighting layout (design in emergency & exit lights)\n-Wiring & Control.\nSecurity System:\n- CCTV system.\nSolar System:\n- Solar Power System layout.\n- AC/DC Panel design & components integration.\nBMS System:\n- BMS design.\n- Schedule of needed components (mechanical & electrical)\n- Final MEP Design Drawings (CAD & PDF).\n- Bill of Quantities (Excel & PDF).\n- Technical Specifications (PDF).",
          "discount_amount": 0.0,
          "sequence": 0,
          "custom_field": "[]",
          "tax_amount": 0.0,
          "discount_rate": 0.0,
          "unique_key_fk_quotation": "faf928921104a4121746032850049",
          "unique_key_fk_product": "faf928921104a4121746015735315",
          "unique_key_quotation_product": "faf928921104a4121746032902471",
          "estimate_product_code": "",
          "taxable_flag": 0,
          "tax_list": "[]"
        },
        {
          "local_id": 602,
          "local_quot_id": 0,
          "local_product_id": 0,
          "product_name": "Drawings",
          "qty": 1.0,
