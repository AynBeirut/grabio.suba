# Grabio Invoice Manager — copy to .env.local (never commit .env.local)

# Firebase (market-flow-7b074) — optional; prod build falls back to baked defaults in client.ts
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=grabio.space
VITE_FIREBASE_PROJECT_ID=market-flow-7b074
VITE_FIREBASE_STORAGE_BUCKET=market-flow-7b074.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=997465465802
VITE_FIREBASE_APP_ID=1:997465465802:web:3c6789ea41a9458a98e533

# Module gate — set true to match grabio.space production enforcement
VITE_ECOSYSTEM_ENFORCE_MODULES=false

# Play Store v1 nav: auto | force | off (auto = trim menu in TWA/installed PWA only)
VITE_PLAY_STORE_V1_NAV=auto

# Legacy Supabase (dev only — remove when Phase A1 Firestore data layer ships)
# VITE_USE_SUPABASE_LEGACY=true
