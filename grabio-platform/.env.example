# ============================================================
# Grabio Platform — Supabase Version (grabio.online)
# Copy this to .env and fill in Supabase values
# ============================================================

# Supabase (get from: supabase.com → Project Settings → API)
VITE_SUPABASE_URL=https://[your-project-ref].supabase.co
VITE_SUPABASE_ANON_KEY=[your-anon-key]

# Cloudflare R2
VITE_R2_UPLOAD_ENABLED=true
VITE_R2_PUBLIC_URL=https://media.grabio.online

# Feature flags
VITE_USE_SUPABASE=true

# Test domain
VITE_APP_DOMAIN=grabio.online
VITE_APP_URL=https://grabio.online

# Firebase Auth domain override (for parallel-run period — mobile apps still use Firebase)
VITE_FIREBASE_AUTH_DOMAIN=grabio.online

# Firebase (read-only during parallel week — DO NOT remove until full cutover)
VITE_FIREBASE_API_KEY=AIzaSyA0jzU0136sQM4QpBz6J0TYEsPn2JDTn1U
VITE_FIREBASE_PROJECT_ID=market-flow-7b074
