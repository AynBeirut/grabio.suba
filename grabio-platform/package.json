{
  "name": "market-flow",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:invoice",
    "build:main": "vite build",
    "build:invoice": "npm run build --prefix \"../finance/beirut-finance-flow-main\" && node scripts/copy-invoice-dist.cjs",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "health:inventory:lint": "node scripts/health/checkInventoryLintGate.cjs",
    "health:inventory:type": "node scripts/health/checkInventoryTypes.cjs",
    "health:inventory": "npm run health:inventory:lint && npm run health:inventory:type",
    "lint:domain:report": "node scripts/health/domainLintDebt.cjs",
    "lint:domain:inventory": "eslint src/pages/admin/AdminOrders.tsx src/pages/admin/AdminFinishedGoods.tsx src/pages/admin/AdminPurchases.tsx src/lib/salesRules.ts src/types/inventory.ts",
    "lint:domain:payments": "eslint src/pages/admin/AdminAccountStatement.tsx src/pages/admin/AdminPayments.tsx src/pages/admin/AdminSupplierCredits.tsx src/pages/admin/AdminBankReconciliation.tsx functions/src/api/checkout.ts functions/src/api/subscription.ts functions/src/api/webhooks.ts functions/src/services/whishPayment.ts",
    "lint:domain:mobile": "eslint grabio-mobile/src/**/*.{ts,tsx}",
    "preview": "vite preview",
    "reconcile:daily-stock": "node scripts/reconcileDailyOrderVsLedger.cjs",
    "test": "vitest",
    "test:inventory-invariants": "vitest run src/__tests__/inventoryTransitionInvariants.test.ts",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run src/__tests__",
    "test:watch": "vitest watch",
    "test:firestore-rules": "JAVA_HOME=\"$HOME/.local/jdk/jre-21\" PATH=\"$HOME/.local/jdk/jre-21/bin:$PATH\" firebase emulators:exec --only firestore \"node scripts/testFirestoreRules.cjs\"",
    "test:builder-phase1": "npm run build --prefix functions && node scripts/testStoreCommerceGuard.cjs && JAVA_HOME=\"$HOME/.local/jdk/jre-21\" PATH=\"$HOME/.local/jdk/jre-21/bin:$PATH\" firebase emulators:exec --only firestore \"node scripts/testFirestoreRules.cjs\"",
    "supabase:deploy-functions": "bash scripts/deploy-supabase-functions.sh"
  },
