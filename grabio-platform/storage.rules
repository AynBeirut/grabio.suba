rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Product images — flat path used by web admin upload
    // Path: products/{filename}
    match /products/{filename} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024  // 10 MB max
        && request.resource.contentType.matches('image/.*');
    }

    // Product images — authenticated store owners can upload to their own store path
    // Path: products/images/{storeId}/{filename}
    match /products/images/{storeId}/{filename} {
      // Anyone can read product images (public store images)
      allow read: if true;
      // Only authenticated users can upload, and only to their own storeId path
      allow write: if request.auth != null
        && request.auth.uid == storeId
        && request.resource.size < 10 * 1024 * 1024  // 10 MB max
        && request.resource.contentType.matches('image/.*');
    }

    // Store logos and banners
    // Path: stores/{storeId}/{filename}
    match /stores/{storeId}/{filename} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == storeId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // POS installers
    // Path: pos/{filename}
    match /pos/{filename} {
      allow read: if true;
      allow write: if false;
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
